{
  "name": "titan-labs-crm",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/backend",
    "packages/frontend"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace=packages/backend",
    "dev:frontend": "npm run dev --workspace=packages/frontend",
    "build": "npm run build --workspaces",
    "migrate:latest": "npm run migrate:latest --workspace=packages/backend",
    "migrate:rollback": "npm run migrate:rollback --workspace=packages/backend",
    "seed": "npm run seed --workspace=packages/backend"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
